generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  ADMIN
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model LegacyAdmin {
  adminid  Int     @id @default(autoincrement())
  username String? @db.VarChar(50)
  password String? @db.VarChar(255)
  status   Int?

  @@map("admin")
}

model LegacyUser {
  id         Int     @id @default(autoincrement())
  username   String? @db.VarChar(255)
  email      String? @db.VarChar(255)
  password   String? @db.VarChar(255)
  name       String? @db.VarChar(255)
  status     Int?
  created_on String? @db.VarChar(50)
  country    String? @db.VarChar(100)
  city       String? @db.VarChar(100)

  @@map("users")
}

model LegacyAdminLog {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(250)
  entrydate String @db.VarChar(250)
  dept      String @db.VarChar(250)
  ip        String @db.VarChar(250)

  @@map("adminlog")
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String?
  role     Role    @default(ADMIN)

  sessions Session[]
  accounts Account[]
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

// ─── NEWSLETTER ──────────────────────────────────────────────────────────────

model Newsletter {
  id           Int    @id @default(autoincrement())
  email        String @db.VarChar(255)
  email_status Int
  status       Int

  @@map("newsletter")
}

// ─── NEWS ────────────────────────────────────────────────────────────────────

model News {
  id          Int    @id @default(autoincrement())
  title       String @db.VarChar(255)
  description String @db.Text
  shortdesc   String @db.Text
  smallimage  String @db.VarChar(255)
  org_img     String @db.VarChar(250)
  status      Int
  imageurl    String @db.VarChar(255)

  @@map("news")
}

model LatestNews {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String   @db.Text
  shortdesc   String   @db.Text
  smallimage  String   @db.VarChar(255)
  org_img     String   @db.VarChar(250)
  status      Int
  date_time   DateTime @default(now())
  post_by     Int

  @@map("latestnews")
}

// ─── HALL OF FAME ─────────────────────────────────────────────────────────────

model HallOfFame {
  id             Int     @id @default(autoincrement())
  title          String? @db.VarChar(255)
  categoryid     Int?
  description    String? @db.Text
  status         Int?
  feature        Int?
  thumb_img      String? @db.VarChar(200)
  image          String? @db.VarChar(255)
  org_img        String? @db.VarChar(250)
  Profession     String? @db.VarChar(255)
  d              String  @db.VarChar(255)
  m              String  @db.VarChar(255)
  y              Int
  address        String? @db.VarChar(255)
  City           String? @db.VarChar(255)
  Country        String? @db.VarChar(255)
  Email          String? @db.VarChar(255)
  Telephone      String? @db.VarChar(255)
  Mobile         String? @db.VarChar(255)
  Interests      String? @db.VarChar(255)
  shortdesc      String? @db.Text
  user_id        Int
  meta_title     String? @db.VarChar(255)
  meta_desc      String? @db.VarChar(255)
  meta_keyword   String? @db.VarChar(255)
  cat            Int     @default(1)
  claim          Int     @default(0)
  phonenumber    String? @db.VarChar(20)
  claim_comments String? @db.Text
  claim_by       Int?
  facebook       String  @db.Text
  linkedin       String  @db.Text
  twitter        String  @db.Text
  video_intro    String  @db.Text
  edu_degree     String  @db.VarChar(255)
  edu_year       String  @db.VarChar(5)
  edu_institute  String  @db.VarChar(500)
  edu_desc       String  @db.Text
  contact_allow  Int
  comments_alow  Int
  allow_fb_page  Int

  @@map("halloffame")
}

model HallCategory {
  categoryid   Int    @id @default(autoincrement())
  categoryname String @db.VarChar(255)
  status       Int

  @@map("hallcategory")
}

model HallOfFameRating {
  i          Int    @id @default(autoincrement())
  id         Int
  rating     Int
  ip         String @db.VarChar(50)
  dateposted String @db.VarChar(100)
  timestamp  Int

  @@map("ratings")
}

